{
	"name": "@twocaretcat/mock-pkg",
	"version": "1.1.0",
	"license": "MIT",
	"exports": "./src/index.ts",
	"exclude": [
		"npm/"
	],
	"tasks": {
		"upgrade-interactive": {
			"description": "Upgrade all dependencies interactively.",
			"command": "deno outdated --interactive --update --latest"
		},
		"version": {
			"description": "Sets the version in deno.json.\n\nUSAGE: deno task version <version>",
			"command": "deno run --allow-read=deno.json --allow-write=deno.json scripts/update-version.ts"
		},
		"build:npm": {
			"description": "Build the package for npm.",
			"command": "deno run --allow-read --allow-write --allow-env --allow-run=npm scripts/build-npm.ts && deno fmt"
		},
		"publish:npm": {
			"description": "Build and publish the package to npm.",
			"command": "cd npm && npm publish",
			"dependencies": [
				"build:npm"
			]
		},
		"publish:jsr": {
			"description": "Copy the README into the package directory and publish the package to JSR.",
			"command": "deno publish --allow-dirty"
		}
	},
	"fmt": {
		"useTabs": true,
		"lineWidth": 120,
		"singleQuote": true,
		"exclude": [
			"**/*.svg",
			"!npm/"
		]
	},
	"lint": {
		"rules": {
			"tags": [
				"recommended",
				"workspace",
				"jsr"
			]
		}
	},
	"publish": {
		"include": [
			"src/**/*.ts",
			"README.md"
		]
	},
	"compilerOptions": {
		"strict": true,
		"checkJs": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true
	},
	"allowScripts": [
		"npm:puppeteer"
	],
	"nodeModulesDir": "auto",
	"unstable": [
		"fmt-component"
	],
	"imports": {
		"@deno/dnt": "jsr:@deno/dnt@^0.42.3",
		"@semantic-release/exec": "npm:@semantic-release/exec@^7.1.0",
		"@semantic-release/git": "npm:@semantic-release/git@^10.0.1",
		"conventional-changelog-conventionalcommits": "npm:conventional-changelog-conventionalcommits@^9.3.1",
		"semantic-release": "npm:semantic-release@^25.0.3"
	}
}
